# ============================================================================
# C++ Build Artifacts
# ============================================================================

# CMake build directory
build/

# Compiled binaries (root-level, from older builds)
dpi_engine
dpi_simple
packet_analyzer
dpi_engine_asan

# Debug symbol bundles (macOS)
*.dSYM/

# Object files
*.o
*.obj

# Compiled libraries
*.a
*.so
*.dylib
*.lib
*.dll

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# ============================================================================
# PCAP Files (test data — generated, not source code)
# ============================================================================
*.pcap
*.pcapng
*.cap

# ============================================================================
# DPI Engine Output (runtime generated)
# ============================================================================
dpi_output/
output/
test_output/

# ============================================================================
# Python
# ============================================================================

# Bytecode cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env

# Pytest cache
.pytest_cache/

# Distribution / packaging
dist/
*.egg-info/
*.egg
*.whl

# ============================================================================
# IDE & Editor
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================================
# Docker (runtime volumes, not config)
# ============================================================================
# Keep docker-compose*.yml and Dockerfiles, ignore runtime data
data/
!netanalyzer/data/rules.json

# ============================================================================
# Misc
# ============================================================================
*.log
*.tmp
*.bak
